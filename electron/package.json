{
  "name": "mixpiloteai-desktop",
  "version": "1.0.0",
  "description": "MixPilote AI — Full-featured Electron desktop application for music production",
  "main": "main.js",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_ENV=development electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "@julusian/midi": "^2.0.1",
    "electron": "^28.0.0",
    "electron-store": "^8.2.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron-builder": "^24.9.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.mixpiloteai.app",
    "productName": "MixPilote AI",
    "files": [
      "main.js",
      "preload.js",
      "src/**",
      "../frontend/dist/**"
    ],
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "extraMetadata": {
      "main": "main.js"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns",
      "category": "public.app-category.music"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Audio"
    }
  }
}
