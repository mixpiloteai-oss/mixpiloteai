{
  "name": "neurotek-ai",
  "version": "1.0.0-beta.1",
  "description": "NeuroTek AI — Professional AI Music Production Desktop App",
  "main": "main.js",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_ENV=development electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win --x64",
    "build:win:portable": "electron-builder --win portable --x64",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "@julusian/midi": "^2.0.1",
    "electron": "^28.0.0",
    "electron-store": "^8.2.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron-builder": "^24.9.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "ai.neurotek.desktop",
    "productName": "NeuroTek AI",
    "copyright": "Copyright © 2025 NeuroTek AI. All rights reserved.",
    "asar": true,
    "compression": "maximum",
    "files": [
      "main.js",
      "preload.js",
      "src/**",
      "!src/**/*.test.js",
      "../frontend/dist/**",
      "!../frontend/dist/**/*.map"
    ],
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "extraMetadata": {
      "main": "main.js"
    },
    "fileAssociations": [
      {
        "ext": "ntai",
        "name": "NeuroTek AI Project",
        "description": "NeuroTek AI music production project",
        "mimeType": "application/x-neurotek-ai"
      }
    ],
    "protocols": [
      {
        "name": "NeuroTek AI",
        "schemes": ["neurotek"]
      }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico",
      "publisherName": "NeuroTek AI",
      "verifyUpdateCodeSignature": false,
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NeuroTek AI",
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "menuCategory": "NeuroTek AI",
      "artifactName": "NeuroTek-AI-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "NeuroTek-AI-Portable-${version}.${ext}"
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "icon": "assets/icon.icns",
      "category": "public.app-category.music",
      "darkModeSupport": true,
      "artifactName": "NeuroTek-AI-${version}.${ext}"
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "icon": "assets/icon.png",
      "category": "Audio",
      "artifactName": "NeuroTek-AI-${version}.${ext}"
    },
    "publish": null
  }
}
