{
  "name": "neurotek-ai-electron",
  "version": "0.1.0",
  "description": "NEUROTEK AI — Electron desktop wrapper",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "electron": "^28.0.0"
  },
  "devDependencies": {
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "com.neurotek.ai",
    "productName": "NEUROTEK AI",
    "directories": { "output": "dist" },
    "linux": { "target": "AppImage" },
    "mac": { "target": "dmg" },
    "win": { "target": "nsis" }
  }
}
