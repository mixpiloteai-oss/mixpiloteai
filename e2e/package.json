{
  "name": "neurotek-e2e",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=22" },
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:admin": "playwright test --grep @admin",
    "test:payments": "playwright test --grep @payments",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
