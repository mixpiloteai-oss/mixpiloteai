    "codegen": "playwright codegen",
    "install:browsers": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.0.0",
    "dotenv": "^16.3.1",
    "typescript": "^5.3.2"
  }
}
