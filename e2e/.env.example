# ──────────────────────────────────────────────────────────────────────────────
# Playwright E2E environment — copy to .env (gitignored) and fill in.
# ──────────────────────────────────────────────────────────────────────────────

# Target URLs
E2E_WEBSITE_URL=https://app.staging.neurotek.ai
E2E_BACKEND_URL=https://api.staging.neurotek.ai

# Auto-start local servers (1 = start backend + website via webServer config)
E2E_WEB_SERVER=0

# Admin credentials — staging only
E2E_ADMIN_EMAIL=admin@staging.neurotek.ai
E2E_ADMIN_PASSWORD=replace-me-staging-password
E2E_ADMIN_KEY=nt-admin-dev-2025

# Test users (provisioned via /api/auth/register before running)
E2E_USER_EMAIL=playwright-user@example.com
E2E_USER_PASSWORD=Playwright!Test2026

# Stripe sandbox — test mode keys only, NEVER live keys
E2E_STRIPE_PUBLIC_KEY=pk_test_replace
E2E_STRIPE_SECRET_KEY=sk_test_replace
E2E_STRIPE_WEBHOOK_SECRET=whsec_test_replace

# Stripe test cards (see https://stripe.com/docs/testing)
E2E_STRIPE_CARD_SUCCESS=4242424242424242
E2E_STRIPE_CARD_DECLINE=4000000000000002
E2E_STRIPE_CARD_3DS=4000002500003155

# PayPal sandbox
E2E_PAYPAL_CLIENT_ID=replace-sandbox-client-id
E2E_PAYPAL_SECRET=replace-sandbox-secret
E2E_PAYPAL_BUYER_EMAIL=sb-buyer@business.example.com
E2E_PAYPAL_BUYER_PASSWORD=replace-sandbox-password

# Optional: Slack notifier for failed runs (used by CI workflow)
E2E_SLACK_WEBHOOK_URL=

# CI marker — Playwright reads this and switches to retry/parallel mode
CI=
