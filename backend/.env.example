# ============================================================
# NEUROTEK AI — Backend Environment Variables
# Copy to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Server
PORT=4000
NODE_ENV=development

# ── Supabase (production database) ──────────────────────────
# Get these from: https://supabase.com/dashboard → project → Settings → API
SUPABASE_URL=https://REPLACE.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJSEPLACE

# If SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY are not set, the backend
# falls back to an in-memory mock DB (demo users only, data resets on restart).

# ── Claude AI API (server-side only — NEVER expose to clients) ─
CLAUDE_API_KEY=sk-ant-api03-REPLACE_WITH_YOUR_KEY
CLAUDE_MODEL=claude-opus-4-7
CLAUDE_MAX_TOKENS=2048

# ── JWT Auth ─────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string-minimum-64-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace-with-another-long-random-string-minimum-64-chars
JWT_REFRESH_EXPIRES_IN=30d

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# Development:
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Production (set in Railway/Render dashboard):
# CORS_ORIGINS=https://mixpiloteai.vercel.app,https://neurotek.ai

# ── Rate limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_FREE=5
RATE_LIMIT_MAX_PRO=30
RATE_LIMIT_MAX_STUDIO=100

# ── Daily AI quota per plan ───────────────────────────────────
QUOTA_FREE_DAILY=10
QUOTA_PRO_DAILY=200
QUOTA_STUDIO_DAILY=9999

# ── Internal service token (backend ↔ AI microservice) ───────
INTERNAL_SERVICE_TOKEN=replace-with-internal-secret-token
