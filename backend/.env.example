# ============================================================
# NEUROTEK AI — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Server
PORT=4000
NODE_ENV=development

# ── Claude API (COMPANY KEY — never expose to clients) ──────
CLAUDE_API_KEY=sk-ant-api03-REPLACE_WITH_YOUR_KEY
CLAUDE_MODEL=claude-opus-4-7
CLAUDE_MAX_TOKENS=2048

# ── JWT Auth ─────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string-minimum-64-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace-with-another-long-random-string
JWT_REFRESH_EXPIRES_IN=30d

# ── Internal service token (backend ↔ AI microservice) ──────
INTERNAL_SERVICE_TOKEN=replace-with-internal-secret-token

# ── Rate limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_FREE=5
RATE_LIMIT_MAX_PRO=30
RATE_LIMIT_MAX_STUDIO=100

# ── Quota (daily AI requests per plan) ──────────────────────
QUOTA_FREE_DAILY=20
QUOTA_PRO_DAILY=200
QUOTA_STUDIO_DAILY=9999

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
