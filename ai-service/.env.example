# ============================================================
# NEUROTEK AI — Python AI Microservice Environment Variables
# ============================================================

# Claude API key (ONLY on the server, NEVER sent to clients)
CLAUDE_API_KEY=sk-ant-api03-REPLACE_WITH_YOUR_KEY
CLAUDE_MODEL=claude-opus-4-7

# Internal service auth token (must match backend INTERNAL_SERVICE_TOKEN)
INTERNAL_SERVICE_TOKEN=replace-with-internal-secret-token

# Service port
PORT=8000
