# NeuroTek AI — Website Environment Variables
# Copy to .env.local for local development. Never commit .env.local.
# Set production values in: Vercel dashboard → Settings → Environment Variables

# ── Backend API URL ───────────────────────────────────────────────────────────
# The Railway backend URL. This is the ONLY env var the frontend needs.
# Vite prefix VITE_ is required — values without it are not bundled into the JS.

# Local development:
VITE_API_URL=http://localhost:8080

# Production (set this in Vercel — do NOT commit production values here):
# VITE_API_URL=https://mixpiloteai-production.up.railway.app
