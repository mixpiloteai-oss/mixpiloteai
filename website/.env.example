# NeuroTek AI — Website Environment Variables
# Copy to .env.local for local development. Never commit .env.local.
# Set production values in: Vercel dashboard → Settings → Environment Variables

# API Backend URL
VITE_API_URL=https://mixpiloteai-production.up.railway.app

# Analytics (optional)
VITE_POSTHOG_KEY=

# Stripe public key (for checkout)
VITE_STRIPE_PUBLIC_KEY=pk_live_...
